@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">Student Manager System</h1>
    <p class="lead mt-3">A comprehensive portal to manage student records, contact information, and enrollment details.</p>

    <hr class="my-4" />

    <div class="row justify-content-center mt-5">
        <div class="col-md-5 mb-4">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body mt-3">
                    <h4 class="card-title text-primary">Student Directory</h4>
                    <p class="card-text mb-4">View, search, edit, and delete existing student records in the database.</p>

                    <a asp-controller="Students" asp-action="List" class="btn btn-outline-primary btn-lg">View All Students</a>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card h-100 shadow-sm border-success">
                <div class="card-body mt-3">
                    <h4 class="card-title text-success">Enrollment</h4>
                    <p class="card-text mb-4">Register a new student into the system with their personal and emergency contact details.</p>

                    <a asp-controller="Students" asp-action="Add" class="btn btn-success btn-lg">Add New Student</a>
                </div>
            </div>
        </div>
    </div>
</div>